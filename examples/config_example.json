{
  "comment": "Example configuration for Windows LLM Benchmarking Suite",
  "comment2": "Edit src/config.json for your actual benchmark run",

  "models": [
    {
      "name": "Qwen2.5-1.5B-Instruct",
      "hf_id": "Qwen/Qwen2.5-1.5B-Instruct",
      "size": "1.5B",
      "category": "small"
    },
    {
      "name": "Llama-3.2-1B-Instruct",
      "hf_id": "meta-llama/Llama-3.2-1B-Instruct",
      "size": "1B",
      "category": "small"
    },
    {
      "name": "Phi-3.5-mini-Instruct",
      "hf_id": "microsoft/Phi-3.5-mini-instruct",
      "size": "3.8B",
      "category": "small"
    },
    {
      "name": "Qwen2.5-7B-Instruct",
      "hf_id": "Qwen/Qwen2.5-7B-Instruct",
      "size": "7B",
      "category": "medium"
    },
    {
      "name": "Mistral-7B-Instruct-v0.3",
      "hf_id": "mistralai/Mistral-7B-Instruct-v0.3",
      "size": "7B",
      "category": "medium"
    }
  ],

  "runtimes": [
    "llama_cpp",
    "ollama",
    "pytorch",
    "onnx"
  ],

  "quantizations": [
    "fp16",
    "int8",
    "q4"
  ],

  "workload_types": [
    "interactive_chat",
    "structured_output",
    "long_context"
  ],

  "experiments": {
    "num_trials": 3,
    "warm_start_trials": 2,
    "cold_start_trials": 1,
    "max_tokens": 256,
    "timeout_seconds": 60
  },

  "dataset": {
    "name": "squad_v2",
    "samples": 250,
    "seed": 42
  },

  "output": {
    "results_dir": "results",
    "save_raw_results": true,
    "generate_summary": true,
    "generate_decision_matrix": true,
    "export_csv": true
  },

  "system": {
    "log_level": "INFO",
    "check_gpu": true,
    "gpu_memory_fraction": 0.8,
    "num_workers": 4
  }
}
